/* Top 20 requêtes par I/O logique/physique via Query Store (SQL 2017) */

SELECT TOP 20
    rs.avg_duration / 1000.0           AS avg_duration_ms,
    rs.avg_cpu_time / 1000.0           AS avg_cpu_ms,
    rs.avg_logical_io_reads            AS avg_logical_io_reads_pages,
    rs.avg_logical_io_writes           AS avg_logical_io_writes_pages,
    rs.avg_physical_io_reads           AS avg_physical_io_reads_pages,
    rs.avg_num_physical_io_reads       AS avg_physical_io_reads_ops,
    rs.count_executions,
    rs.last_execution_time,
    qt.query_sql_text,
    qp.query_plan
FROM sys.query_store_runtime_stats       AS rs
JOIN sys.query_store_plan                AS qp ON rs.plan_id = qp.plan_id
JOIN sys.query_store_query               AS q  ON qp.query_id = q.query_id
JOIN sys.query_store_query_text          AS qt ON q.query_text_id = qt.query_text_id
WHERE rs.execution_type = 0  -- exécutions "Regular"
ORDER BY rs.avg_physical_io_reads DESC;  -- ou avg_logical_io_reads selon ton focus

Remarques :
	•	avg_duration et avg_cpu_time sont en microsecondes, donc je divise par 1000 pour avoir des millisecondes.
	•	Les *_io_reads sont en pages de 8 Ko, avg_num_physical_io_reads en nombre d’IOs.  ￼

Intégration propre dans ton script d’audit

Dans ta grosse procédure d’audit, au lieu de faire un PRINT avec le bloc texte, tu peux mettre à la fin :

PRINT '--- 7. Query Store (à exécuter dans chaque base avec QS actif) ---';
PRINT '--- Exemple : USE MaBase; puis exécuter le bloc suivant ---';

et garder ce SELECT comme un bloc séparé à lancer base par base (Query Store étant par base, pas au niveau instance).



;WITH SessionInfo AS
(
    SELECT
        s.session_id,
        COALESCE(r.blocking_session_id, 0) AS blocking_session_id,
        s.login_name,
        s.host_name,
        s.program_name,
        s.status           AS session_status,
        r.status           AS request_status,
        r.command,
        r.wait_type,
        r.wait_time,
        r.cpu_time,
        r.total_elapsed_time,
        r.reads,
        r.writes,
        DB_NAME(r.database_id) AS database_name
    FROM sys.dm_exec_sessions s
    LEFT JOIN sys.dm_exec_requests r
        ON s.session_id = r.session_id
    WHERE s.is_user_process = 1          -- seulement les sessions utilisateur
      AND s.session_id <> @@SPID         -- on exclut ta propre session
      AND (s.status <> 'sleeping' OR r.session_id IS NOT NULL)  -- sessions actives
),
BlockingTree AS
(
    -- Racines : sessions non bloquées (ou sans info de blocage)
    SELECT
        s.*,
        CAST(RIGHT('0000' + CAST(s.session_id AS varchar(4)), 4) AS varchar(4000)) AS sort_path,
        0 AS level
    FROM SessionInfo s
    WHERE s.blocking_session_id = 0
       OR s.blocking_session_id IS NULL

    UNION ALL

    -- Enfants : sessions bloquées par un parent déjà dans l’arbre
    SELECT
        c.*,
        p.sort_path + '-' + RIGHT('0000' + CAST(c.session_id AS varchar(4)), 4),
        p.level + 1
    FROM SessionInfo c
    JOIN BlockingTree p
        ON c.blocking_session_id = p.session_id
)
SELECT
    REPLICATE('¦   ', level) +
    CASE WHEN level > 0 THEN '→ ' ELSE '' END +
    CAST(session_id AS varchar(10)) AS session_tree,   -- arborescence visuelle
    session_id,
    blocking_session_id        AS bloque_par,
    login_name,
    host_name,
    program_name,
    session_status,
    request_status,
    command,
    wait_type,
    wait_time,
    cpu_time,
    total_elapsed_time,
    reads,
    writes,
    database_name
FROM BlockingTree
ORDER BY sort_path;


voir le role control server

SELECT pr.name, pe.permission_name, pe.state_desc
FROM sys.server_permissions AS pe
JOIN sys.server_principals AS pr
  ON pe.grantee_principal_id = pr.principal_id
WHERE pe.permission_name = 'CONTROL SERVER';









SELECT  
    bs.database_name,
    bs.backup_start_date,
    bs.backup_finish_date,
    CASE bs.type
        WHEN 'D' THEN 'Full'
        WHEN 'I' THEN 'Differential'
        WHEN 'L' THEN 'Log'
        ELSE bs.type
    END AS backup_type,
    bmf.physical_device_name AS backup_file,
    CAST(bs.backup_size / 1024 / 1024 AS DECIMAL(10,2)) AS backup_size_MB,
    CAST(bs.compressed_backup_size / 1024 / 1024 AS DECIMAL(10,2)) AS compressed_size_MB,
    CAST((1 - (bs.compressed_backup_size * 1.0 / NULLIF(bs.backup_size,0))) * 100 AS DECIMAL(5,2)) AS compression_ratio_percent
FROM msdb.dbo.backupset bs
JOIN msdb.dbo.backupmediafamily bmf ON bs.media_set_id = bmf.media_set_id
WHERE bs.backup_start_date = (
    SELECT MAX(backup_start_date)
    FROM msdb.dbo.backupset bs2
    WHERE bs2.database_name = bs.database_name
      AND bs2.type = bs.type
)
ORDER BY bs.database_name, bs.backup_start_date DESC;

