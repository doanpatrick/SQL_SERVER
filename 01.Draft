    mailitem_id,
    sent_status,
    recipients,
    subject,
    send_request_date,
    sent_date
FROM msdb.dbo.sysmail_allitems
ORDER BY mailitem_id DESC;

-- 6️⃣ Derniers événements (erreurs, warnings, succès)
SELECT TOP 20
    log_date,
    event_type,
    description
FROM msdb.dbo.sysmail_event_log
ORDER BY log_date DESC;





