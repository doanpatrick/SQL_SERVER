supprimer dossier en cascade

$Path = "\\Serveur\Share\Backups"
$Days = 35
$Cutoff = (Get-Date).AddDays(-$Days)

Get-ChildItem -Path $Path -Recurse -Directory |
Where-Object {
    $_.LastWriteTime -lt $Cutoff -and
    (Get-ChildItem $_.FullName -Force | Measure-Object).Count -eq 0
} |
Remove-Item -Force -Verbose





test sans supprimer dossier en cascade


Get-ChildItem -Path $Path -Recurse -Directory |
Where-Object {
    $_.LastWriteTime -lt (Get-Date).AddDays(-35) -and
    (Get-ChildItem $_.FullName -Force | Measure-Object).Count -eq 0
} |
Select FullName, LastWriteTime









