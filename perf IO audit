Vue timeline complète — I/O + CPU + Durée


SELECT
    rsi.start_time,
    rsi.end_time,
    COUNT(DISTINCT q.query_id)                                                  AS nb_requetes,
    SUM(rs.count_executions)                                                    AS total_executions,

    -- I/O
    SUM(rs.avg_logical_io_reads  * rs.count_executions)                         AS total_logical_reads,
    SUM(rs.avg_logical_io_writes * rs.count_executions)                         AS total_logical_writes,
    SUM(rs.avg_physical_io_reads * rs.count_executions)                         AS total_physical_reads,

    -- CPU (microsecondes -> secondes)
    SUM(rs.avg_cpu_time * rs.count_executions) / 1000000.0                      AS total_cpu_sec,
    SUM(rs.avg_cpu_time * rs.count_executions)
        / NULLIF(SUM(rs.count_executions), 0) / 1000.0                          AS avg_cpu_ms_par_exec,

    -- Durée (microsecondes -> secondes)
    SUM(rs.avg_duration * rs.count_executions) / 1000000.0                      AS total_duree_sec,
    SUM(rs.avg_duration * rs.count_executions)
        / NULLIF(SUM(rs.count_executions), 0) / 1000.0                          AS avg_duree_ms_par_exec,

    -- Mémoire (KB)
    SUM(rs.avg_query_max_used_memory * rs.count_executions) * 8                 AS total_memoire_kb,

    -- Parallélisme
    SUM(rs.avg_dop * rs.count_executions)
        / NULLIF(SUM(rs.count_executions), 0)                                   AS avg_dop

FROM sys.query_store_runtime_stats          rs
JOIN sys.query_store_runtime_stats_interval rsi
        ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
JOIN sys.query_store_plan                   p
        ON p.plan_id  = rs.plan_id
JOIN sys.query_store_query                  q
        ON q.query_id = p.query_id
WHERE rsi.start_time >= '2026-04-01'
  AND rsi.end_time   <= '2026-05-01'
  AND rs.execution_type = 0              -- exécutions normales uniquement
ORDER BY rsi.start_time;

Comparaison avant / après — toutes métriques

WITH stats AS (
    SELECT
        CASE
            WHEN rsi.start_time >= '2026-04-01' AND rsi.end_time <= '2026-04-15' THEN 'Avant'
            WHEN rsi.start_time >= '2026-04-16' AND rsi.end_time <= '2026-04-30' THEN 'Après'
        END                                                                 AS periode,
        rs.count_executions,
        rs.avg_logical_io_reads,
        rs.avg_logical_io_writes,
        rs.avg_physical_io_reads,
        rs.avg_cpu_time,
        rs.avg_duration,
        rs.avg_query_max_used_memory,
        rs.avg_dop
    FROM sys.query_store_runtime_stats          rs
    JOIN sys.query_store_runtime_stats_interval rsi
            ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
    WHERE rs.execution_type = 0
      AND (
            (rsi.start_time >= '2026-04-01' AND rsi.end_time <= '2026-04-15')
         OR (rsi.start_time >= '2026-04-16' AND rsi.end_time <= '2026-04-30')
          )
),
agrege AS (
    SELECT
        periode,
        SUM(count_executions)                                               AS total_exec,
        SUM(avg_logical_io_reads  * count_executions)
            / NULLIF(SUM(count_executions), 0)                              AS avg_logical_reads,
        SUM(avg_logical_io_writes * count_executions)
            / NULLIF(SUM(count_executions), 0)                              AS avg_logical_writes,
        SUM(avg_physical_io_reads * count_executions)
            / NULLIF(SUM(count_executions), 0)                              AS avg_physical_reads,
        SUM(avg_cpu_time          * count_executions)
            / NULLIF(SUM(count_executions), 0) / 1000.0                     AS avg_cpu_ms,
        SUM(avg_duration          * count_executions)
            / NULLIF(SUM(count_executions), 0) / 1000.0                     AS avg_duree_ms,
        SUM(avg_query_max_used_memory * count_executions) * 8
            / NULLIF(SUM(count_executions), 0)                              AS avg_mem_kb,
        SUM(avg_dop               * count_executions)
            / NULLIF(SUM(count_executions), 0)                              AS avg_dop
    FROM stats
    WHERE periode IS NOT NULL
    GROUP BY periode
)
SELECT
    a.periode,
    a.total_exec,
    a.avg_logical_reads,
    a.avg_logical_writes,
    a.avg_physical_reads,
    a.avg_cpu_ms,
    a.avg_duree_ms,
    a.avg_mem_kb,
    a.avg_dop
FROM agrege a

UNION ALL

SELECT
    'Variation %',
    (ap.total_exec       - av.total_exec)       * 100 / NULLIF(av.total_exec, 0),
    (ap.avg_logical_reads  - av.avg_logical_reads)  * 100 / NULLIF(av.avg_logical_reads, 0),
    (ap.avg_logical_writes - av.avg_logical_writes) * 100 / NULLIF(av.avg_logical_writes, 0),
    (ap.avg_physical_reads - av.avg_physical_reads) * 100 / NULLIF(av.avg_physical_reads, 0),
    (ap.avg_cpu_ms         - av.avg_cpu_ms)         * 100 / NULLIF(av.avg_cpu_ms, 0),
    (ap.avg_duree_ms       - av.avg_duree_ms)       * 100 / NULLIF(av.avg_duree_ms, 0),
    (ap.avg_mem_kb         - av.avg_mem_kb)         * 100 / NULLIF(av.avg_mem_kb, 0),
    (ap.avg_dop            - av.avg_dop)            * 100 / NULLIF(av.avg_dop, 0)
FROM agrege av
JOIN agrege ap ON av.periode = 'Avant' AND ap.periode = 'Après';


