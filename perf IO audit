Requête pour voir l'évolution des I/O d'une requête


SELECT
    q.query_id,
    qt.query_sql_text,
    rs.runtime_stats_interval_id,
    rsi.start_time,
    rsi.end_time,
    rs.avg_logical_io_reads,
    rs.avg_physical_io_reads,
    rs.avg_logical_io_writes,
    rs.count_executions
FROM sys.query_store_query          q
JOIN sys.query_store_query_text     qt  ON qt.query_text_id   = q.query_text_id
JOIN sys.query_store_plan           p   ON p.query_id         = q.query_id
JOIN sys.query_store_runtime_stats  rs  ON rs.plan_id         = p.plan_id
JOIN sys.query_store_runtime_stats_interval rsi
                                        ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
WHERE q.query_id = <ton_query_id>   -- ou filtre sur le texte
ORDER BY rsi.start_time;


Pour trouver les requêtes les plus gourmandes en I/O

SELECT TOP 20
    q.query_id,
    qt.query_sql_text,
    SUM(rs.avg_logical_io_reads * rs.count_executions) AS total_logical_reads,
    SUM(rs.avg_physical_io_reads * rs.count_executions) AS total_physical_reads,
    SUM(rs.count_executions) AS total_executions
FROM sys.query_store_query          q
JOIN sys.query_store_query_text     qt  ON qt.query_text_id = q.query_text_id
JOIN sys.query_store_plan           p   ON p.query_id       = q.query_id
JOIN sys.query_store_runtime_stats  rs  ON rs.plan_id       = p.plan_id
GROUP BY q.query_id, qt.query_sql_text
ORDER BY total_logical_reads DESC;

Vue globale des I/O par intervalle de temps

SELECT
    rsi.start_time,
    rsi.end_time,
    COUNT(DISTINCT q.query_id)                                      AS nb_requetes,
    SUM(rs.count_executions)                                        AS total_executions,
    SUM(rs.avg_logical_io_reads  * rs.count_executions)             AS total_logical_reads,
    SUM(rs.avg_logical_io_writes * rs.count_executions)             AS total_logical_writes,
    SUM(rs.avg_physical_io_reads * rs.count_executions)             AS total_physical_reads,
    -- Moyennes par exécution
    SUM(rs.avg_logical_io_reads  * rs.count_executions)
        / NULLIF(SUM(rs.count_executions), 0)                       AS avg_logical_reads_par_exec,
    SUM(rs.avg_physical_io_reads * rs.count_executions)
        / NULLIF(SUM(rs.count_executions), 0)                       AS avg_physical_reads_par_exec
FROM sys.query_store_runtime_stats          rs
JOIN sys.query_store_runtime_stats_interval rsi
        ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
JOIN sys.query_store_plan                   p
        ON p.plan_id   = rs.plan_id
JOIN sys.query_store_query                  q
        ON q.query_id  = p.query_id
WHERE rsi.start_time >= '2026-04-01'
  AND rsi.end_time   <= '2026-05-01'
ORDER BY rsi.start_time;

Comparer deux périodes (avant / après)


WITH periode_avant AS (
    SELECT
        SUM(rs.avg_logical_io_reads  * rs.count_executions) AS total_logical_reads,
        SUM(rs.avg_physical_io_reads * rs.count_executions) AS total_physical_reads,
        SUM(rs.avg_logical_io_writes * rs.count_executions) AS total_logical_writes,
        SUM(rs.count_executions)                            AS total_executions
    FROM sys.query_store_runtime_stats          rs
    JOIN sys.query_store_runtime_stats_interval rsi
            ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
    WHERE rsi.start_time >= '2026-04-01'
      AND rsi.end_time   <= '2026-04-15'
),
periode_apres AS (
    SELECT
        SUM(rs.avg_logical_io_reads  * rs.count_executions) AS total_logical_reads,
        SUM(rs.avg_physical_io_reads * rs.count_executions) AS total_physical_reads,
        SUM(rs.avg_logical_io_writes * rs.count_executions) AS total_logical_writes,
        SUM(rs.count_executions)                            AS total_executions
    FROM sys.query_store_runtime_stats          rs
    JOIN sys.query_store_runtime_stats_interval rsi
            ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
    WHERE rsi.start_time >= '2026-04-16'
      AND rsi.end_time   <= '2026-04-30'
)
SELECT
    'Avant'                         AS periode,
    a.total_executions,
    a.total_logical_reads,
    a.total_physical_reads,
    a.total_logical_writes
FROM periode_avant a
UNION ALL
SELECT
    'Après',
    b.total_executions,
    b.total_logical_reads,
    b.total_physical_reads,
    b.total_logical_writes
FROM periode_apres b
UNION ALL
SELECT
    'Delta (Après - Avant)',
    b.total_executions    - a.total_executions,
    b.total_logical_reads - a.total_logical_reads,
    b.total_physical_reads- a.total_physical_reads,
    b.total_logical_writes- a.total_logical_writes
FROM periode_avant a, periode_apres b
UNION ALL
SELECT
    'Variation %',
    (b.total_executions     - a.total_executions)     * 100 / NULLIF(a.total_executions, 0),
    (b.total_logical_reads  - a.total_logical_reads)  * 100 / NULLIF(a.total_logical_reads, 0),
    (b.total_physical_reads - a.total_physical_reads) * 100 / NULLIF(a.total_physical_reads, 0),
    (b.total_logical_writes - a.total_logical_writes) * 100 / NULLIF(a.total_logical_writes, 0)
FROM periode_avant a, periode_apres b;


Identifier les requêtes qui ont le plus dégradé entre deux périodes


WITH avant AS (
    SELECT
        q.query_id,
        qt.query_sql_text,
        SUM(rs.avg_logical_io_reads * rs.count_executions)
            / NULLIF(SUM(rs.count_executions), 0)   AS avg_logical_reads
    FROM sys.query_store_runtime_stats          rs
    JOIN sys.query_store_runtime_stats_interval rsi ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
    JOIN sys.query_store_plan                   p   ON p.plan_id  = rs.plan_id
    JOIN sys.query_store_query                  q   ON q.query_id = p.query_id
    JOIN sys.query_store_query_text             qt  ON qt.query_text_id = q.query_text_id
    WHERE rsi.start_time >= '2026-04-01' AND rsi.end_time <= '2026-04-15'
    GROUP BY q.query_id, qt.query_sql_text
),
apres AS (
    SELECT
        q.query_id,
        SUM(rs.avg_logical_io_reads * rs.count_executions)
            / NULLIF(SUM(rs.count_executions), 0)   AS avg_logical_reads
    FROM sys.query_store_runtime_stats          rs
    JOIN sys.query_store_runtime_stats_interval rsi ON rsi.runtime_stats_interval_id = rs.runtime_stats_interval_id
    JOIN sys.query_store_plan                   p   ON p.plan_id  = rs.plan_id
    JOIN sys.query_store_query                  q   ON q.query_id = p.query_id
    WHERE rsi.start_time >= '2026-04-16' AND rsi.end_time <= '2026-04-30'
    GROUP BY q.query_id
)
SELECT TOP 20
    av.query_id,
    LEFT(av.query_sql_text, 100)            AS sql_extrait,
    av.avg_logical_reads                    AS avg_reads_avant,
    ap.avg_logical_reads                    AS avg_reads_apres,
    ap.avg_logical_reads - av.avg_logical_reads AS delta,
    (ap.avg_logical_reads - av.avg_logical_reads)
        * 100 / NULLIF(av.avg_logical_reads, 0) AS variation_pct
FROM avant av
JOIN apres ap ON ap.query_id = av.query_id
WHERE ap.avg_logical_reads > av.avg_logical_reads
ORDER BY delta DESC;

