5️⃣ Avant / Après incident (preuve béton)
Comparer deux périodes
SQL
WITH stats AS (
    SELECT
        qt.query_sql_text,
        CASE 
            WHEN rsi.start_time < '2026-03-20' THEN 'AVANT'
            ELSE 'APRES'
        END AS periode,
        AVG(rs.avg_duration) AS avg_duration,
        AVG(rs.avg_logical_io_reads) AS logical_reads
    FROM sys.query_store_runtime_stats rs
    JOIN sys.query_store_plan p ON rs.plan_id = p.plan_id
    JOIN sys.query_store_query q ON p.query_id = q.query_id
    JOIN sys.query_store_query_text qt ON q.query_text_id = qt.query_text_id
    JOIN sys.query_store_runtime_stats_interval rsi
        ON rs.runtime_stats_interval_id = rsi.runtime_stats_interval_id
    WHERE rsi.start_time BETWEEN '2026-03-10' AND '2026-04-10'
    GROUP BY qt.query_sql_text,
             CASE 
               WHEN rsi.start_time < '2026-03-20' THEN 'AVANT'
               ELSE 'APRES'
             END
)
SELECT *
FROM stats
WHERE avg_duration > 2 * (
    SELECT MIN(avg_duration) FROM stats s2 WHERE s2.query_sql_text = stats.query_sql_text
)
ORDER BY avg_duration DESC;
